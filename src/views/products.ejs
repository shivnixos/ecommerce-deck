<% include ../layouts/main %>

<% block content %>
<h1>Our Products</h1>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card">
            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Smart Watch">
            <div class="card-body">
                <h5 class="card-title">Smart Watch Pro</h5>
                <p class="card-text">Advanced smartwatch with health monitoring and GPS tracking.</p>
                <p class="card-text"><strong>$199.99</strong></p>
                <a href="#" class="btn btn-primary">Add to Cart</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Wireless Headphones">
            <div class="card-body">
                <h5 class="card-title">Wireless Headphones</h5>
                <p class="card-text">Premium noise-cancelling headphones with 30-hour battery life.</p>
                <p class="card-text"><strong>$149.99</strong></p>
                <a href="#" class="btn btn-primary">Add to Cart</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Fitness Tracker">
            <div class="card-body">
                <h5 class="card-title">Fitness Tracker</h5>
                <p class="card-text">Track your steps, heart rate, and sleep patterns.</p>
                <p class="card-text"><strong>$79.99</strong></p>
                <a href="#" class="btn btn-primary">Add to Cart</a>
            </div>
        </div>
    </div>
    <!-- NEW PRODUCT ADDED BY AUTOMATED UPDATE -->
    <div class="col-md-4 mb-4">
        <div class="card new-item">
            <div class="featured-badge">NEW</div>
            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Bluetooth Speaker">
            <div class="card-body">
                <h5 class="card-title">Portable Bluetooth Speaker</h5>
                <p class="card-text">Waterproof speaker with 360-degree sound and 12-hour battery.</p>
                <p class="card-text"><strong>$89.99</strong></p>
                <a href="#" class="btn btn-primary">Add to Cart</a>
            </div>
        </div>
    </div>
    <!-- DELIVERY MODE PRODUCT ADDED -->
    <div class="col-md-4 mb-4">
        <div class="card new-item">
            <div class="featured-badge">NEW</div>
            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Drone Delivery Service">
            <div class="card-body">
                <h5 class="card-title">Drone Delivery Service</h5>
                <p class="card-text">Get your products delivered by drone within 30 minutes!</p>
                <p class="card-text"><strong>FREE with orders over $100</strong></p>
                <a href="#" class="btn btn-success">Add to Cart</a>
            </div>
        </div>
    </div>
</div>
