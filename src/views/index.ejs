<% include ../layouts/main %>

<% block content %>
<div class="jumbotron">
    <h1 class="display-4">Welcome to E-Commerce Deck</h1>
    <p class="lead">Discover amazing products at great prices.</p>
    <hr class="my-4">
    <p>Explore our latest collection with new arrivals every week!</p>
    <a class="btn btn-primary btn-lg" href="/products" role="button">Shop Now</a>
</div>

<!-- NEW FEATURE ADDED BY AUTOMATED UPDATE -->
<div class="alert alert-info mt-3" role="alert">
    <strong>New Feature:</strong> Free shipping on all orders over $50! Limited time offer.
</div>

<!-- DELIVERY MODE SECTION -->
<div class="delivery-options mt-4">
    <h3>🚀 Express Delivery Options</h3>
    <div class="row">
        <div class="col-md-4">
            <h5>Standard Delivery</h5>
            <p>3-5 business days • Free</p>
        </div>
        <div class="col-md-4">
            <h5>Express Delivery</h5>
            <p>1-2 business days • $5.99</p>
        </div>
        <div class="col-md-4">
            <h5>Drone Delivery</h5>
            <p>30 minutes or less • $19.99</p>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Free Shipping</h5>
                <p class="card-text">Free shipping on orders over $50.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Easy Returns</h5>
                <p class="card-text">30-day return policy.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Secure Payment</h5>
                <p class="card-text">Your payment information is secure.</p>
            </div>
        </div>
    </div>
    <!-- NEW SERVICE ADDED BY AUTOMATED UPDATE -->
    <div class="col-md-4 mt-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">24/7 Support</h5>
                <p class="card-text">Round-the-clock customer support available.</p>
            </div>
        </div>
    </div>
</div>
